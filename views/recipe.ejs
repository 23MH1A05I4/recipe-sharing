<!DOCTYPE html>
<html>
<head>
    <title>Recipe Details</title>

    <style>
        body {
            margin: 0;
            font-family: Arial, sans-serif;

    
            background: linear-gradient(135deg, #89f7fe, #66a6ff);
            height: 100vh;
        }

        .container {
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100%;
        }

        .card {
            background: white;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.2);
            width: 900px;
        }

        h2 {
            text-align: center;
            margin-bottom: 20px;
        }

        .row {
            display: flex;
            gap: 30px;
        }

        .section {
            flex: 1;
        }

        .section h3 {
            border-bottom: 2px solid #eee;
            padding-bottom: 5px;
        }

        img {
            width: 100%;
            border-radius: 10px;
        }

        .back {
            display: block;
            text-align: center;
            margin-top: 20px;
            text-decoration: none;
            color: #007bff;
            font-weight: bold;
        }

        .back:hover {
            text-decoration: underline;
        }

    </style>
</head>

<body>

<div class="container">

<div class="card">

<h2> <%= recipe.title %></h2>

<div class="row">

   
    <div class="section">
        <h3>Ingredients</h3>
        <p><%= recipe.ingredients %></p>
    </div>

    
    <div class="section">
        <h3>Process</h3>
        <p><%= recipe.instructions %></p>
    </div>

  
    <div class="section">
        <h3>Image</h3>
        <img src="/<%= recipe.imagePath %>"/>
    </div>

</div>

<a href="/search" class="back"> Back to Search</a>

</div>

</div>

</body>
</html>