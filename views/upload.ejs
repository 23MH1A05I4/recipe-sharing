<!DOCTYPE html>
<html>
<head>
    <title>Upload Recipe</title>

    <style>
        body {
            margin: 0;
            font-family: Arial, sans-serif;

            background: linear-gradient(135deg, #f6d365, #fda085);
            height: 100vh;
        }

        .container {
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100%;
        }

        .card {
            background: white;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.2);
            width: 900px;
        }

        h2 {
            text-align: center;
            margin-bottom: 20px;
        }

        .row {
            display: flex;
            gap: 30px;
            justify-content: space-between;
        }

        .section {
            flex: 1;
        }

        input, textarea {
            width: 100%;
            padding: 10px;
            border-radius: 8px;
            border: 1px solid #ccc;
            margin-bottom: 10px;
        }

        textarea {
            resize: none;
        }

        input[type="file"] {
            border: none;
        }

        button {
            width: 100%;
            padding: 12px;
            border: none;
            background: #ff6b6b;
            color: white;
            border-radius: 10px;
            font-size: 16px;
            cursor: pointer;
        }

        button:hover {
            background: #ff4757;
        }

        .back {
            display: block;
            text-align: center;
            margin-top: 15px;
            text-decoration: none;
            color: #ff6b6b;
        }

        .back:hover {
            text-decoration: underline;
        }

    </style>
</head>

<body>

<div class="container">

<div class="card">

<h2> Upload Recipe</h2>

<form action="/upload" method="post" enctype="multipart/form-data">

<div class="row">

   
    <div class="section">
        <h3>Ingredients</h3>

        <input type="text" name="ingredients" placeholder="1">
        <input type="text" name="ingredients" placeholder="2">
        <input type="text" name="ingredients" placeholder="3">
        <input type="text" name="ingredients" placeholder="4">
        <input type="text" name="ingredients" placeholder="5">
    </div>

  
    <div class="section">
        <h3>Recipe Name</h3>
        <input type="text" name="title" placeholder="Enter recipe name">

        <h3>Process</h3>
        <textarea name="instructions" rows="12" placeholder="Write cooking process..."></textarea>
    </div>

  
    <div class="section">
        <h3>Recipe Image</h3>
        <input type="file" name="image">

        <p style="font-size:12px; color:gray;">
             Upload image
        </p>
    </div>

</div>

<br>

<button> Upload Recipe</button>

</form>



</div>

</div>

</body>
</html>